{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/pages/About",
      "destination": "/About",
      "permanent": true
    },
    {
      "source": "/pages/Blog",
      "destination": "/Blog",
      "permanent": true
    },
    {
      "source": "/pages/Contact",
      "destination": "/Contact",
      "permanent": true
    },
    {
      "source": "/pages/Privacy",
      "destination": "/privacy-policy-for-friddy",
      "permanent": true
    },
    {
      "source": "/pages/Privacy-ko",
      "destination": "/ko-privacy-policy-for-friddy",
      "permanent": true
    },
    {
      "source": "/pages/Terms",
      "destination": "/Terms",
      "permanent": true
    },
    {
      "source": "/Privacy",
      "destination": "/privacy-policy-for-friddy",
      "permanent": true
    },
    {
      "source": "/Privacy-ko",
      "destination": "/ko-privacy-policy-for-friddy",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
